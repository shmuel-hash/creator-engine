# ─── Creator Discovery Engine ───
# Copy this to .env and fill in your values

# Database (Railway auto-populates this from Postgres plugin)
DATABASE_URL=sqlite+aiosqlite:///./creator_engine.db

# Anthropic (AI intent parsing + creator analysis + outreach strategies)
ANTHROPIC_API_KEY=sk-ant-...

# SearchAPI.io (web search for creator discovery)
SERPER_API_KEY=your-searchapi-key

# ClickUp (sync creators to your pipeline)
CLICKUP_API_TOKEN=pk_...

# Gmail OAuth (for sending outreach emails - set up later)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Redis (for background jobs - optional)
REDIS_URL=

# App
APP_SECRET_KEY=change-this-to-random-string
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENV=development
